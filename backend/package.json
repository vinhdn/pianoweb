{
  "name": "pianobeauty-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:push": "prisma db push --config prisma/prisma.config.ts",
    "db:migrate": "prisma migrate deploy --config prisma/prisma.config.ts",
    "db:seed": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed.ts",
    "db:studio": "prisma studio --config prisma/prisma.config.ts",
    "postinstall": "prisma generate --config prisma/prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "pg": "^8.14.1",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.29",
    "nodemon": "^3.1.10",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
